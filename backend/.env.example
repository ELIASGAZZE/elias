# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase > Project Settings > API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL_2=               # (opcional) segunda URL de frontend para CORS
# BACKEND_URL=http://localhost:3001  # (opcional) URL pública del backend, usado por cron jobs

# ── Centum ERP (API REST) ────────────────────────────────────────────────────
CENTUM_BASE_URL=https://plataforma5.centum.com.ar:23990/BL7
CENTUM_API_KEY=tu-api-key-centum
CENTUM_CONSUMER_ID=2
CENTUM_CLIENT_ID=2
CENTUM_OPERADOR_PRUEBA_USER=api123

# ── Centum BI (SQL Server) ───────────────────────────────────────────────────
CENTUM_BI_SERVER=tu-servidor-sql
CENTUM_BI_PORT=22455
CENTUM_BI_DATABASE=CentumSuiteBL7
CENTUM_BI_USER=tu-usuario-bi
CENTUM_BI_PASSWORD=tu-password-bi
# CENTUM_BI_ENCRYPT=true        # (opcional) default true

# ── AFIP (facturación electrónica) ───────────────────────────────────────────
# AFIP_CERT=                    # (opcional) certificado AFIP en base64, o se carga desde archivo
# AFIP_KEY=                     # (opcional) clave privada AFIP en base64
# AFIP_ACCESS_TOKEN=            # (opcional) token de acceso AFIP

# ── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=tu-mp-access-token
# MP_WEBHOOK_SECRET=            # (opcional) secret para validar webhooks de MP

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=mail.ejemplo.com
SMTP_PORT=465
SMTP_USER=comprobantes@ejemplo.com
SMTP_PASS=tu-password-smtp

# ── Push Notifications (VAPID) ───────────────────────────────────────────────
VAPID_SUBJECT=mailto:admin@ejemplo.com
VAPID_PUBLIC_KEY=tu-vapid-public-key
VAPID_PRIVATE_KEY=tu-vapid-private-key

# ── Talo (links de pago) ────────────────────────────────────────────────────
TALO_USER_ID=tu-talo-user-id
TALO_CLIENT_ID=tu-talo-client-id
TALO_CLIENT_SECRET=tu-talo-client-secret

# ── Claude AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=tu-anthropic-api-key

# ── MCP Server ───────────────────────────────────────────────────────────────
# MCP_API_URL=http://localhost:3001  # (opcional) URL interna para MCP
# MCP_USER=elias                     # (opcional) usuario MCP
# MCP_PASSWORD=admin123              # (opcional) password MCP

# ── Otros ────────────────────────────────────────────────────────────────────
EMERGENCY_PIN=1234
# GOOGLE_SHEET_NOTIFICACIONES_ID=   # (opcional) ID de Google Sheet para notificaciones
# COMPROBANTE_SECRET=               # (opcional) secret para URLs de comprobantes públicos
