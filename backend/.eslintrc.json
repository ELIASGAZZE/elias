{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|next|req|res" }],
    "no-console": "off",
    "semi": ["warn", "never"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "no-var": "error",
    "prefer-const": "warn"
  }
}
